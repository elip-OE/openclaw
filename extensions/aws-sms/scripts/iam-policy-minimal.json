{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AwsSmsSend",
      "Effect": "Allow",
      "Action": ["sms-voice:SendTextMessage", "sms-voice:SendMediaMessage"],
      "Resource": "*"
    },
    {
      "Sid": "AwsSmsRead",
      "Effect": "Allow",
      "Action": [
        "sms-voice:DescribePhoneNumbers",
        "sms-voice:DescribePools",
        "sms-voice:UpdatePhoneNumber"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AwsSmsInboundTopic",
      "Effect": "Allow",
      "Action": [
        "sns:Subscribe",
        "sns:ConfirmSubscription",
        "sns:ListSubscriptionsByTopic",
        "sns:GetTopicAttributes"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AwsSmsMmsStaging",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::REPLACE_WITH_MEDIA_BUCKET",
        "arn:aws:s3:::REPLACE_WITH_MEDIA_BUCKET/*"
      ]
    }
  ]
}
