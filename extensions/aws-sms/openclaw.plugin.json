{
  "id": "aws-sms",
  "name": "AWS SMS",
  "description": "AWS End User Messaging SMS channel plugin for OpenClaw text and MMS messages.",
  "activation": {
    "onStartup": false
  },
  "channels": ["aws-sms"],
  "channelEnvVars": {
    "aws-sms": [
      "AWS_REGION",
      "AWS_DEFAULT_REGION",
      "AWS_ACCESS_KEY_ID",
      "AWS_SECRET_ACCESS_KEY",
      "AWS_SESSION_TOKEN",
      "AWS_PROFILE",
      "AWS_SMS_ORIGINATION_IDENTITY",
      "AWS_SMS_FROM_NUMBER",
      "AWS_SMS_INBOUND_TOPIC_ARN",
      "AWS_SMS_PUBLIC_WEBHOOK_URL",
      "AWS_SMS_WEBHOOK_PATH",
      "AWS_SMS_MEDIA_BUCKET"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  }
}
